# Copy this file to terraform.tfvars and update with your values
# Command: cp terraform.tfvars.example terraform.tfvars

aws_region    = "us-east-1"
project_name  = "devops-pipeline-demo"
environment   = "dev"
instance_type = "t3.micro"

# IMPORTANT: Replace with your actual SSH key pair name
# This key must already exist in your AWS account
key_name = "your-key-pair-name"

# AMI ID for Ubuntu 22.04 LTS
# Update based on your selected region
# us-east-1: ami-0866a3c8686eaeeba
# us-west-2: ami-0aff18ec83b712f05
# eu-west-1: ami-0694d931cee176e7d
ami_id = "ami-0866a3c8686eaeeba"
